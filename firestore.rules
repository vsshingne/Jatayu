rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all users under any document
    // This is for testing purposes - should be restricted in production
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Task collections
    match /activeTasks/{taskId} {
      allow read, write: if true;
    }
    
    match /ongoingTasks/{taskId} {
      allow read, write: if true;
    }
    
    match /completedTasks/{taskId} {
      allow read, write: if true;
    }
    
    // Detection collections
    match /detected_garbage/{detectionId} {
      allow read, write: if true;
    }
    
    match /drone_sessions/{sessionId} {
      allow read, write: if true;
    }
    
    // User collections
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Test collection for diagnostics
    match /test/{testId} {
      allow read, write: if true;
    }
  }
} 